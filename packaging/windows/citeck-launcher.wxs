<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v5 authoring for the Citeck Launcher per-user MSI.
  Build (on Windows, run from the REPO ROOT): wix build packaging/windows/citeck-launcher.wxs \
      -arch x64 -d Version=2.3.2 -b . -o dist/citeck-launcher_2.3.2_windows_amd64.msi
  The `-b .` adds the repo root as a bind path so the relative File/Icon Source
  paths (dist\bin\citeck-launcher.exe, icons\logo.ico) resolve during binding.
  UpgradeCode is intentionally identical to the legacy 1.* jpackage MSI
  (upgradeUuid in build.gradle.kts @ v1.4.1) so MajorUpgrade removes 1.* on install.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Citeck Launcher"
           Manufacturer="Citeck LLC"
           Version="$(Version)"
           UpgradeCode="3FA61060-0739-4463-985E-C58D1BC4E9B2"
           Scope="perUser"
           Compressed="yes">

    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of Citeck Launcher is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="AppIcon" SourceFile="icons/logo.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="Citeck Launcher" />
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="Citeck Tools" />
    </StandardDirectory>

    <!-- Fixed GUID (not "*") so component identity is stable across 2.x releases. -->
    <Component Id="MainExe" Directory="INSTALLFOLDER" Guid="824BB0B5-2F67-483E-8489-DF9545AFB47B">
      <File Id="CiteckLauncherExe" Source="dist\bin\citeck-launcher.exe" KeyPath="yes" />
    </Component>

    <Component Id="StartMenuShortcut" Directory="AppMenuFolder" Guid="*">
      <Shortcut Id="AppShortcut"
                Name="Citeck Launcher"
                Target="[INSTALLFOLDER]citeck-launcher.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="AppIcon" />
      <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\Citeck\Launcher"
                     Name="installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Feature Id="Main" Title="Citeck Launcher" Level="1">
      <ComponentRef Id="MainExe" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <!--
      Launch the app right after a fresh install / upgrade so the user does not
      have to hunt for the Start-menu shortcut (the installed exe was otherwise
      left un-started). Type-18 custom action: run the installed file directly
      (FileRef), no Util extension needed. Impersonate="yes" launches it in the
      installing USER's session (the MSI is perUser, so that is the right
      context for a GUI app); Return="ignore" keeps a launch failure from
      failing the install. Sequenced after InstallFinalize (the exe is on disk
      by then). Condition "NOT Installed" fires on first install and on the
      install half of a MajorUpgrade, but NOT on uninstall (Installed is true).

      Return="asyncNoWait" is LOAD-BEARING: the launcher is a long-running GUI
      process that never exits on its own, so a synchronous return ("ignore"
      still WAITS for the process, only the exit code is ignored) leaves msiexec
      blocked on it — the progress dialog hangs on "Cancelling…" and Windows
      reports the install as still in progress, blocking other installers.
      asyncNoWait spawns the exe and returns immediately so InstallFinalize
      completes cleanly.
    -->
    <CustomAction Id="LaunchApplication"
                  FileRef="CiteckLauncherExe"
                  ExeCommand=""
                  Execute="immediate"
                  Impersonate="yes"
                  Return="asyncNoWait" />
    <InstallExecuteSequence>
      <Custom Action="LaunchApplication" After="InstallFinalize" Condition="NOT Installed" />
    </InstallExecuteSequence>
  </Package>
</Wix>
