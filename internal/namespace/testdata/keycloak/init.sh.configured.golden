#!/bin/bash
#
# Keycloak init script — runs after container startup to ensure the
# "citeck" service account exists, update the ecos-proxy-app OIDC client
# config, and optionally apply the ecos-app admin password.
#
# Generated from internal/appfiles/embedded/keycloak/init.sh.tmpl.
#
# All user-derived values below are rendered via the bash-safe `shquote`
# template function (single-quoted, with internal quotes escaped as
# '\''), so they are safe against shell injection even for pathological
# inputs such as $(...), backticks, or embedded newlines.
set -e
KCADM=/opt/keycloak/bin/kcadm.sh
KC=/opt/keycloak/bin/kc.sh
SA_USER='citeck'
SA_PASS='sa-secret-32chars-abcdefghijklmno'
LEGACY_SA_USER='citeck-launcher'
ADMIN_PASS='strong-admin-pass'
BASE_URL='https://citeck.example.com'
OIDC_SECRET='prod-oidc-secret'
KC_DB_URL='jdbc:postgresql://postgres:5432/citeck_keycloak'
KC_DB_USER='citeck_keycloak'
KC_DB_PASS='citeck_keycloak'
AUTHENTICATED=false

# Try service account first (normal steady-state)
if [ -n "$SA_PASS" ] && $KCADM config credentials --server http://localhost:8080 \
    --realm master --user "$SA_USER" --password "$SA_PASS" 2>/dev/null; then
  AUTHENTICATED=true
  echo "Authenticated as $SA_USER"
fi

# Try legacy SA (pre-rename upgrades — same password, old username).
# Once re-authenticated below as the new SA, the legacy user is deleted.
if [ "$AUTHENTICATED" = "false" ] && [ -n "$SA_PASS" ] && [ -n "$LEGACY_SA_USER" ]; then
  if $KCADM config credentials --server http://localhost:8080 \
      --realm master --user "$LEGACY_SA_USER" --password "$SA_PASS" 2>/dev/null; then
    AUTHENTICATED=true
    echo "Authenticated as legacy SA $LEGACY_SA_USER"
  fi
fi

# Fall back to admin (fresh install or snapshot import)
if [ "$AUTHENTICATED" = "false" ]; then
  if $KCADM config credentials --server http://localhost:8080 \
      --realm master --user admin --password "$ADMIN_PASS" 2>/dev/null; then
    AUTHENTICATED=true
    echo "Authenticated as admin (target password)"
  elif $KCADM config credentials --server http://localhost:8080 \
      --realm master --user admin --password admin 2>/dev/null; then
    AUTHENTICATED=true
    echo "Authenticated as admin (default password)"
  fi
fi

# Last-resort recovery: create a temporary master-realm admin via
# `kc.sh bootstrap-admin user` (writes directly to the DB, requires no
# existing credentials). Used when the master realm was modified out-of-band
# (snapshot import with mismatched SA, manual DB edit, lost passwords).
# Created user auto-expires after ~120 min; we also delete it explicitly at
# the end of this block.
if [ "$AUTHENTICATED" = "false" ] && [ -n "$KC_DB_URL" ]; then
  RECOVERY_USER="_citeck_recover_$(date +%s%N)"
  RECOVERY_PASS="$(head -c 24 /dev/urandom | base64 | tr -d '=+/' | head -c 32)"
  echo "All standard auth paths failed — attempting bootstrap-admin recovery..."
  # Capture exit code of kc.sh itself (not `tail`); the pipe-suffix would
  # otherwise mask a kc.sh crash and let the misleading "succeeded" branch
  # log even though no recovery user was created.
  RECOVERY_PASS_ENV="$RECOVERY_PASS" $KC bootstrap-admin user \
      --optimized \
      --db-url="$KC_DB_URL" --db-username="$KC_DB_USER" --db-password="$KC_DB_PASS" \
      --http-management-port=0 \
      --username "$RECOVERY_USER" --password:env RECOVERY_PASS_ENV \
      --no-prompt > /tmp/kc_bootstrap.log 2>&1
  KC_BOOTSTRAP_RC=$?
  tail -5 /tmp/kc_bootstrap.log
  if [ "$KC_BOOTSTRAP_RC" -eq 0 ]; then
    if $KCADM config credentials --server http://localhost:8080 \
        --realm master --user "$RECOVERY_USER" --password "$RECOVERY_PASS" 2>/dev/null; then
      AUTHENTICATED=true
      echo "Authenticated as bootstrap recovery user $RECOVERY_USER"
    fi
  else
    echo "bootstrap-admin command exited $KC_BOOTSTRAP_RC — recovery unavailable" >&2
  fi
  unset RECOVERY_PASS RECOVERY_PASS_ENV KC_BOOTSTRAP_RC
  rm -f /tmp/kc_bootstrap.log
fi

if [ "$AUTHENTICATED" = "false" ]; then
  echo "ERROR: cannot authenticate to keycloak" >&2
  exit 1
fi

# Ensure "$SA_USER" service account exists (skip if SA_PASS empty — safety)
if [ -z "$SA_PASS" ]; then
  echo "WARN: SA_PASS empty, skipping SA management" >&2
else
  # Exact-match check: Keycloak's `-q username=` is a substring query, so a
  # legacy "citeck-launcher" user would match a query for "citeck" and cause
  # this block to skip creation. Filter by the username column (field 2 in the
  # id,username CSV) and require an exact equality — a plain substring grep
  # on the piped output would silently false-match and skip SA creation.
  # Keycloak 26 image doesn't ship awk — use grep+cut (POSIX-portable, present
  # in any minimal image). `grep -Fxq` matches the username exactly in column 2
  # of the id,username CSV after cutting to that column.
  if ! $KCADM get users -r master -q username="$SA_USER" --fields id,username --format csv --noquotes 2>/dev/null | cut -d',' -f2 | grep -Fxq "$SA_USER"; then
    echo "Creating service account $SA_USER..."
    $KCADM create users -r master -s username="$SA_USER" -s enabled=true
    $KCADM add-roles -r master --uusername "$SA_USER" --rolename admin
  fi
  # Always update SA password to match the launcher secret
  $KCADM set-password -r master --username "$SA_USER" --new-password "$SA_PASS"
  echo "Service account $SA_USER ready"
  # Re-authenticate as SA for remaining operations
  $KCADM config credentials --server http://localhost:8080 \
      --realm master --user "$SA_USER" --password "$SA_PASS" 2>/dev/null || true
  # Delete legacy SA (pre-rename) — idempotent cleanup after upgrade.
  if [ -n "$LEGACY_SA_USER" ] && [ "$LEGACY_SA_USER" != "$SA_USER" ]; then
    # Exact-match on username column: `-q username=` is a substring query, so
    # filter the id,username CSV to rows where column 2 equals the legacy
    # username exactly before picking the id (column 1).
    # Exact match on username column without awk: grep for lines ending in
    # `,<user>` (column 2) then take column 1 (id).
    LEGACY_UID=$($KCADM get users -r master -q username="$LEGACY_SA_USER" --fields id,username --format csv --noquotes 2>/dev/null | grep -F ",$LEGACY_SA_USER" | cut -d',' -f1 | head -1)
    if [ -n "$LEGACY_UID" ]; then
      echo "Deleting legacy SA $LEGACY_SA_USER (id=$LEGACY_UID)..."
      $KCADM delete "users/$LEGACY_UID" -r master 2>/dev/null || echo "WARN: legacy SA delete failed, continuing" >&2
    fi
  fi
fi

# If we entered via bootstrap-admin recovery, the temporary recovery user
# is no longer needed once the script reaches this point (either SA was
# restored above, or SA management was skipped — in both cases the
# recovery user has done its job). Delete it explicitly rather than
# waiting for the ~120 min TTL — leaves a clean master realm.
# Lives OUTSIDE the SA_PASS guard so the cleanup runs even when SA_PASS
# is empty and the SA management block was skipped entirely.
if [ -n "${RECOVERY_USER:-}" ]; then
  RECOVERY_UID=$($KCADM get users -r master -q username="$RECOVERY_USER" --fields id,username --format csv --noquotes 2>/dev/null | grep -F ",$RECOVERY_USER" | cut -d',' -f1 | head -1)
  if [ -n "$RECOVERY_UID" ]; then
    echo "Deleting bootstrap recovery user $RECOVERY_USER (id=$RECOVERY_UID)..."
    $KCADM delete "users/$RECOVERY_UID" -r master 2>/dev/null || echo "WARN: recovery user delete failed, continuing" >&2
  fi
  unset RECOVERY_USER
fi

# Update ecos-proxy-app OIDC client (redirect URIs + secret).
# Exact-match on clientId column: `-q clientId=` is a substring query, so
# filter by column 2 (clientId) equalling "ecos-proxy-app" before picking the
# id (column 1).
CID=$($KCADM get clients -r ecos-app \
    -q clientId=ecos-proxy-app --fields id,clientId \
    --format csv --noquotes | grep -F ",ecos-proxy-app" | cut -d',' -f1 | head -1)
[ -z "$CID" ] && { echo "WARN: ecos-proxy-app client not found"; exit 0; }
$KCADM update "clients/$CID" -r ecos-app -s "redirectUris=[\"${BASE_URL}*\"]"
$KCADM update "clients/$CID" -r ecos-app -s "secret=${OIDC_SECRET}"

# Apply admin password to BOTH realms. Both failures are fatal:
#   - ecos-app: without this, the user-facing platform login is still
#     whatever the realm-import JSON carried (historically "admin").
#   - master: without this, the Keycloak admin console stays on the
#     snapshot's password (historically "admin") — a live security
#     hole once the platform is on a public network. KC_BOOTSTRAP_ADMIN_PASSWORD
#     only creates the INITIAL master user on an empty DB; it's ignored
#     whenever a snapshot is imported and brings its own master admin.
# set -e (top of script) makes a non-zero exit here fail the init
# container, which marks postgres-dependent startup as failed and
# surfaces the problem to the operator instead of silently shipping
# admin/admin on master.
echo "Applying admin password to ecos-app realm..."
$KCADM set-password -r ecos-app --username admin --new-password "$ADMIN_PASS"
echo "Applying admin password to master realm..."
$KCADM set-password -r master --username admin --new-password "$ADMIN_PASS"
echo "Admin password applied."
